SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Direct Postgres connection string for migrations.
# Supabase: Project Settings -> Database -> Connection string.
# Prefer the session/transaction pooler URI if your network blocks direct 5432.
SUPABASE_DB_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project.supabase.co:5432/postgres
# Pooler example:
# SUPABASE_DB_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@[POOLER-HOST]:6543/postgres
# Set to "disable" only for a local non-SSL Postgres.
PGSSL=require
XAI_API_KEY=your-xai-api-key

# Marketplace BI (Phase 0–1)
# MARKETPLACE_CRON_SECRET=shared-cron-secret
# QUEUE_PROCESSOR_KEY=also-accepted-by-marketplace-cron-routes
# Optional logged-in Shopee cookies (JSON array or { "cookies": [...] })
# SHOPEE_SG_SESSION_JSON=[{"name":"SPC_ST","value":"...","domain":".shopee.sg","path":"/"}]
# Optional Cloudflare Browser Rendering collector
# CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_API_TOKEN=
# Preferred cloud collect: Browserbase (residential proxies + captcha solve)
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
# BROWSERBASE_PROXIES=1
# BROWSERBASE_REGION=ap-southeast-1
# BROWSERBASE_SOLVE_CAPTCHAS=1
# BROWSERBASE_ADVANCED_STEALTH=0
# BROWSERBASE_OS=linux
# (windows/mac only on Verified/Enterprise — Developer plan is linux)

# Fran MCP server — npm run mcp
# FRAN_MCP_WORKSPACE_ID=your-workspace-uuid
#
# Scope profiles (M0). Default if unset = safe (draft/propose/read only).
# FRAN_MCP_PROFILE=safe
# FRAN_MCP_SCOPES=safe
# Privileged ops only (submit/decide/execute/seed writes):
# FRAN_MCP_PROFILE=full
# FRAN_MCP_SCOPES=full
# Or custom list:
# FRAN_MCP_SCOPES=intel:read,study:write,pipeline:propose,po:draft,projection:run
#
# Attribution (M1+ audit; set now for future logs)
# FRAN_MCP_CLIENT=cursor
# FRAN_MCP_ACTOR_USER_ID=your-profiles-uuid

